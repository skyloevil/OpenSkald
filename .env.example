# LLM API
DEEPSEEK_API_KEY=

# WeChat Official Account (JSON format)
# Get app_id and app_secret from https://mp.weixin.qq.com -> 设置与开发 -> 基本配置
WECHAT_PUBLISHER_CREDENTIALS={"app_id":"wx_your_app_id","app_secret":"your_app_secret"}

# X / Twitter (JSON format)
# OAuth 1.0a User Context. Get these from X Developer Portal -> App -> Keys and tokens.
# App permissions must be Read and Write; regenerate Access Token and Secret after changing permissions.
X_PUBLISHER_CREDENTIALS={"api_key":"your_consumer_key","api_key_secret":"your_consumer_secret","access_token":"your_access_token","access_token_secret":"your_access_token_secret"}

# Xiaohongshu (JSON format)
# Get cookie from browser DevTools after logging in to https://creator.xiaohongshu.com
XIAOHONGSHU_PUBLISHER_CREDENTIALS={"cookie":"your_session_cookie"}
